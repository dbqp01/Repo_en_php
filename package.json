{
  "name": "usgar-hotels",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "tinacms dev -c \"astro dev\"",
    "dev:php": "php -S localhost:8000 router.php",
    "build": "tinacms build --skip-cloud-checks && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.2",
    "@tinacms/cli": "^2.5.3",
    "astro": "^7.0.6",
    "leaflet": "^1.9.4",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "tinacms": "^3.10.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "puppeteer": "^25.3.0",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "sharp@0.35.3": true,
    "esbuild@0.28.1": true,
    "better-sqlite3@12.11.1": true
  }
}
